# Sneakercare production environment variables
# Copy these into your hosting provider’s environment variable settings.

# Required for booking, gallery, admin dashboard, testimonials, and stored service data.
# Example: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Required only if using Manus/OAuth-backed login and admin authentication.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OWNER_OPEN_ID=
JWT_SECRET=

# Required only if using the map component through the configured proxy.
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional analytics placeholders used by index.html.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional built-in service integrations.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
